<UserControl x:Class="Costing.UserControls.StaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Costing.Viewmodels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="white">

    <UserControl.DataContext>
        <vm:StaffViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Staff Management" FontSize="24" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>

            <Button x:Name="btnImport" Click="btnImport_Click" Content="Import CSV File" Margin="20,0,0,0" Width="120" Height="35" 
                    Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand" ForceCursor="True">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Save to Database" Click="btnSaveToDb_Click" Background="#10B981" Margin="20,0,0,0"/>
        </StackPanel>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding OCStaff}" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#E2E8F0"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#F8FAFC">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100"/>
                <DataGridTextColumn Header="Employee Name" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Cost Centre" Binding="{Binding CostCentre}" Width="200"/>
                <DataGridTextColumn Header="Job Description" Binding="{Binding JobDescription}" Width="*"/>
                <DataGridTextColumn Header="Rate" Binding="{Binding Rate}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
