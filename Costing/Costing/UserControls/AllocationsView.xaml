<UserControl x:Class="Costing.UserControls.AllocationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Staff Work Centre Allocations"
                   FontSize="24" FontWeight="Bold"
                   Foreground="#1E293B"
                   Margin="0,0,0,20"/>

        <DataGrid Grid.Row="1"
                  x:Name="dgAllocations"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding OCAllocations}"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#E2E8F0"
                  BorderThickness="1"
                  RowBackground="White"
                  AlternatingRowBackground="#F8FAFC"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E2E8F0"
                  SelectionMode="Single">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Code"
                                    Binding="{Binding Code}"
                                    Width="110"/>

                <DataGridTextColumn Header="Employee Name"
                                    Binding="{Binding Name}"
                                    Width="220"/>

                <DataGridTextColumn Header="Work Centre Assignments"
                                    Binding="{Binding AllocationSummary}"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AllocationSummary}" Value="Not assigned">
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="FontStyle" Value="Italic"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Total" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TotalPortion, StringFormat={}{0:0%}}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TotalPortion}" Value="1">
                                                <Setter Property="Foreground" Value="#16A34A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Actions" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Assign"
                                    Tag="{Binding}"
                                    Click="BtnAssign_Click"
                                    FontSize="12"
                                    Height="20"
                                    BorderThickness="0"
                                    Margin="20, 4, 20, 4"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   Text="Click Assign to set work centre allocations for an employee."
                   Foreground="#94A3B8"
                   FontSize="12"
                   Margin="0,16,0,0"/>
    </Grid>
</UserControl>
