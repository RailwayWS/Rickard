<UserControl x:Class="Costing.UserControls.CalculatedStaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Costing.Viewmodels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="White">

    <UserControl.DataContext>
        <vm:CalculatedStaffViewModel/>
    </UserControl.DataContext>


    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--#region Header: title + Run/Save/Record Audit actions -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Calculated Data" FontSize="24" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>

            <Button Content="Run Calculations" 
                    Click="btnRunCalculations_Click" 
                    Style="{StaticResource ModernHeaderButton}"
                    Background="{StaticResource Brush.Primary}" 
                    Margin="20,0,0,0" Width="150" Height="35"/>

            <Button Content="Save to Database" 
                    Click="btnSaveToDb_Click" 
                    Style="{StaticResource ModernHeaderButton}"
                    Background="{StaticResource Brush.Success}" 
                    Margin="15,0,0,0" Width="150" Height="35"/>

            <Button Content="Record Audit Log" 
                    Click="btnRecordAudit_Click" 
                    Style="{StaticResource ModernHeaderButton}"
                    Background="{StaticResource Brush.Purple}" 
                    Margin="15,0,0,0" Width="150" Height="35"/>
        </StackPanel>
        <!--#endregion-->

        <!--#region Progress bar -->
        <StackPanel x:Name="pnlProgress" Grid.Row="1" Visibility="Collapsed" Margin="0,0,0,20">
            <TextBlock x:Name="txtProgress" Text="Calculating: 0%" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,0,0,5"/>

            <ProgressBar x:Name="pbCalculations" Height="10" Minimum="0" Maximum="100" Value="0" 
                         Foreground="#10B981" Background="WhiteSmoke" BorderThickness="0">
                <ProgressBar.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </ProgressBar.Resources>
            </ProgressBar>
        </StackPanel>
        <!--#endregion-->

        <!--#region Data grid: per-employee calculation results -->
        <DataGrid x:Name="CalculatedDataGrid"
                  Grid.Row="2"
                  Style="{StaticResource StandardDataGridStyle}"
                  ItemsSource="{Binding OCCalculatedStaff}"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="60" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                <DataGridTextColumn Header="Work Centre" Binding="{Binding WorkCentre}" Width="120" />

                <DataGridTextColumn Header="Rate/Hr" Binding="{Binding RatePerHour, StringFormat={}{0:N2}}" Width="70" Foreground="#2563EB"/>
                <DataGridTextColumn Header="Alloc." Binding="{Binding Allocation, StringFormat={}{0:N2}}" Width="60" Foreground="#2563EB"/>
                <DataGridTextColumn Header="Eff." Binding="{Binding Efficiency, StringFormat={}{0:N2}}" Width="50" Foreground="#2563EB"/>
                <DataGridTextColumn Header="Rate" Binding="{Binding Rate, StringFormat={}{0:N2}}" Width="80"/>
                <DataGridTextColumn Header="TOTAL" Binding="{Binding Total, StringFormat={}{0:N2}}" Width="110" FontWeight="Bold" Foreground="#059669"/>
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="110" FontWeight="Bold"   Foreground="#7C3AED"/>
            </DataGrid.Columns>
        </DataGrid>
        <!--#endregion-->

        <!--#region Record Audit overlay: snapshot-name prompt -->
        <Border x:Name="pnlAuditInput" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Background="#1E293B" CornerRadius="8" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="10" Opacity="0.5" Direction="270" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Record Audit Log" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                <TextBlock Text="Snapshot Name (e.g. Q1 2026 Audit)" Foreground="#CBD5E1" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtAuditName" Style="{StaticResource DarkTextBoxStyle}" Height="36" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,24"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Cancel" Click="btnCancelAudit_Click" Background="Transparent" BorderBrush="#334155" BorderThickness="1" Foreground="#94A3B8" Height="36" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Grid.Column="2" Content="Confirm" Click="btnConfirmAudit_Click" Background="{StaticResource Brush.Purple}" BorderThickness="0" Foreground="White" Height="36" FontWeight="Bold" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
        <!--#endregion-->

    </Grid>
</UserControl>