<UserControl x:Class="Costing.UserControls.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Application Settings" FontSize="24" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="SETTINGS" FontSize="16" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
    </Grid>
</UserControl>
