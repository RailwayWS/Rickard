<Window x:Class="Costing.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Costing"
        mc:Ignorable="d"
        Title="Costing" Height="768" Width="1024"
        VerticalAlignment="Stretch"
        HorizontalAlignment="Stretch"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="25,15,15,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ForceCursor" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <Grid DockPanel.Dock="Left" Width="280" Background="#1E293B">
            <Grid.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
            </Grid.Effect>

            <Border x:Name="MainMenuSidebar" Visibility="Visible" >
                <Grid Background="#1E293B">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="COSTING" Foreground="White" FontSize="18" FontWeight="Bold" 
               HorizontalAlignment="Center" Margin="0,40,0,30"/>

                    <StackPanel Grid.Row="1">
                        <Button x:Name="btAllocations" Content="Allocations" Click="btAllocations_Click" Style="{StaticResource NavButton}"/>
                        <Button x:Name="btStaffCosts" Content="Staff Costs" Click="btStaffCosts_Click" Style="{StaticResource NavButton}"/>
                        <Button x:Name="btStaff" Content="Staff Management" Click="btStaff_Click" Style="{StaticResource NavButton}"/>
                        <Button x:Name="btSettings" Content="Settings" Style="{StaticResource NavButton}"/>
                    </StackPanel>

                    <Button Grid.Row="2" x:Name="btLogout" Content="Logout" Click="btLogout_Click" 
            Style="{StaticResource NavButton}" Margin="0,0,0,20" Foreground="#FCA5A5"/>
                </Grid>
                
            </Border>
            <ContentControl x:Name="SecondarySidebarFrame" Visibility="Collapsed"/>
        </Grid>

        <ContentControl x:Name="MainFrame"  Background="#F8FAFC"/>

    </DockPanel>
</Window>