<Window x:Class="Costing.UserControls.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Costing.UserControls"
        xmlns:vm="clr-namespace:Costing.Viewmodels"
        mc:Ignorable="d"
        Title="Login" Height="420" Width="360"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.15" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1E293B" CornerRadius="12,12,0,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="COSTING" Foreground="White" FontSize="22" FontWeight="Bold" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Welcome back, please log in." Foreground="#94A3B8" FontSize="12" 
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="30,25,30,20">

                <TextBlock Text="Username" Foreground="#64748B" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbUsers" 
                          ItemsSource="{Binding OCUsers}" 
                          DisplayMemberPath="UserName" 
                          SelectedValuePath="UserName" 
                          SelectedValue="{Binding strUser}" 
                          Height="38" Margin="0,0,0,20" Padding="8,0"
                          VerticalContentAlignment="Center" Background="#F8FAFC"/>

                <TextBlock Text="Password" Foreground="#64748B" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" 
                             Height="38" Margin="0,0,0,35" Padding="8,0"
                             VerticalContentAlignment="Center" Background="#F8FAFC"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="btcancel" Content="Cancel" Click="btcancel_Click" 
                            Style="{StaticResource SecondaryButton}" Height="42"/>

                    <Button Grid.Column="2" x:Name="btOK" Content="Login" Click="btOK_Click" 
                            Style="{StaticResource PrimaryButton}" Height="42" IsDefault="True"/>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</Window>