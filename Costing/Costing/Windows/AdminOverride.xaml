<Window x:Class="Costing.Windows.AdminOverride"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Override" Height="420" Width="360"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True">


    <Border Background="White" CornerRadius="12" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="8" Opacity="0.15" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--#region Header banner -->
            <Border Grid.Row="0" Background="#1E293B" CornerRadius="12,12,0,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ADMIN OVERRIDE" Foreground="White" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Restricted access" Foreground="#94A3B8" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <!--#endregion-->

            <!--#region Override form -->
            <StackPanel Grid.Row="1" Margin="30,25,30,20">

                <TextBlock Text="To bypass login and access Settings directly, enter the admin password below and click Confirm."
                           Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,20"/>

                <TextBlock Text="Admin Password" Foreground="#64748B" FontWeight="SemiBold" 
                           FontSize="12" Margin="0,0,0,5"/>

                <PasswordBox x:Name="txtAdminPassword"
                             Height="38" Margin="0,0,0,30" Padding="8,0"
                             VerticalContentAlignment="Center" Background="#F8FAFC"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Cancel" Click="btnCancel_Click"
                            Style="{StaticResource SecondaryButton}" Height="42" FontSize="14"/>

                    <Button Grid.Column="2" Content="Confirm" Click="btnConfirm_Click"
                            Style="{StaticResource PrimaryButton}" Height="42" IsDefault="True"/>
                </Grid>

            </StackPanel>
            <!--#endregion-->
        </Grid>
    </Border>
</Window>