<Window x:Class="Costing.Other.Message"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Costing.Other"
        mc:Ignorable="d"
        Title="Message" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">

    <Border Background="White" CornerRadius="8" Margin="20" BorderBrush="{StaticResource Brush.CardBorder}" BorderThickness="1">

        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.15" Direction="270" Color="Black"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Notification" 
                       FontFamily="Segoe UI" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource Brush.TextHeading}" 
                       Margin="0,0,0,12"/>

            <TextBlock Grid.Row="1" 
                       Text="{Binding Path=DataContext.message}" 
                       FontFamily="Segoe UI" 
                       FontSize="14" 
                       Foreground="{StaticResource Brush.TextBody}" 
                       TextWrapping="Wrap" 
                       LineHeight="20"
                       MinHeight="40"
                       Margin="0,0,0,24"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">

                <Button x:Name="btcancel" 
                        Content="Cancel" 
                        Click="btcancel_Click" 
                        Style="{StaticResource SecondaryButton}" 
                        Margin="0,0,12,0" 
                        Width="80" Height="36"/>

                <Button x:Name="btOK" 
                        Content="OK" 
                        Click="btok_Click" 
                        IsDefault="True" 
                        Style="{StaticResource PrimaryButton}" 
                        Width="80" Height="36"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>